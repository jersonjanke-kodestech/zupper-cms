{
  "kind": "collectionType",
  "collectionName": "passagem_companhias",
  "info": {
    "singularName": "passagem-companhia",
    "pluralName": "passagem-companhias",
    "displayName": "Passagem Aérea",
    "description": "Cadastro de passagens aéreas por companhia"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "companhia": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "companhia",
      "required": true
    },
    "origem": {
      "type": "string",
      "required": true
    },
    "destino": {
      "type": "string",
      "required": true
    },
    "preco": {
      "type": "decimal",
      "required": true
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "ida",
        "ida_e_volta"
      ],
      "required": true,
      "default": "ida_e_volta"
    },
    "classe": {
      "type": "enumeration",
      "enum": [
        "economica",
        "executiva",
        "primeira_classe"
      ],
      "required": true,
      "default": "economica"
    },
    "data_ida": {
      "type": "date",
      "required": true
    },
    "data_volta": {
      "type": "date"
    },
    "titulo": {
      "type": "string",
      "required": true
    },
    "descricao": {
      "type": "text",
      "required": true
    }
  }
}
