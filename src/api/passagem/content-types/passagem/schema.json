{
  "kind": "collectionType",
  "collectionName": "passagens",
  "info": {
    "singularName": "passagem",
    "pluralName": "passagens",
    "displayName": "Passagem",
    "description": "Passagens aéreas, rodoviárias ou marítimas"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titulo",
      "required": true
    },
    "companhia": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::companhia.companhia",
      "inversedBy": "passagens"
    },
    "origem": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::destino.destino",
      "inversedBy": "passagens_origem"
    },
    "destino_passagem": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::destino.destino",
      "inversedBy": "passagens_destino"
    },
    "data_ida": {
      "type": "datetime",
      "required": true
    },
    "data_volta": {
      "type": "datetime"
    },
    "preco": {
      "type": "decimal",
      "required": true
    },
    "preco_original": {
      "type": "decimal"
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "so_ida",
        "ida_e_volta"
      ],
      "required": true,
      "default": "ida_e_volta"
    },
    "classe": {
      "type": "enumeration",
      "enum": [
        "economica",
        "executiva",
        "primeira_classe"
      ],
      "required": true,
      "default": "economica"
    },
    "bagagem_incluida": {
      "type": "boolean",
      "default": false
    },
    "vagas_disponiveis": {
      "type": "integer"
    },
    "destaque": {
      "type": "boolean",
      "default": false
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "pacotes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::pacote.pacote",
      "mappedBy": "passagem"
    }
  }
}
