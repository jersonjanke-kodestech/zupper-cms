{
  "kind": "collectionType",
  "collectionName": "atracoes",
  "info": {
    "singularName": "atracao",
    "pluralName": "atracoes",
    "displayName": "Atração",
    "description": "Atrações turísticas dos destinos"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "descricao": {
      "type": "richtext",
      "required": true
    },
    "imagem": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "categoria": {
      "type": "enumeration",
      "enum": [
        "parque",
        "museu",
        "gastronomia",
        "historico",
        "natureza",
        "entretenimento",
        "compras",
        "religioso"
      ]
    }
  }
}
