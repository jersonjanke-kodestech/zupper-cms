{
  "kind": "collectionType",
  "collectionName": "companhias",
  "info": {
    "singularName": "companhia",
    "pluralName": "companhias",
    "displayName": "Companhia",
    "description": "Companhias aéreas, rodoviárias ou marítimas"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "codigo_iata": {
      "type": "string"
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "aereo",
        "rodoviario",
        "maritimo"
      ],
      "required": true,
      "default": "aereo"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "ativo": {
      "type": "boolean",
      "default": true
    },
    "passagens": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::passagem.passagem",
      "mappedBy": "companhia"
    }
  }
}
