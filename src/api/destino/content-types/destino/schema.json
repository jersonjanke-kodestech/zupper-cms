{
  "kind": "collectionType",
  "collectionName": "destinos",
  "info": {
    "singularName": "destino",
    "pluralName": "destinos",
    "displayName": "Destino",
    "description": "Guia de destinos de viagem"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "nome",
      "required": true
    },
    "regiao": {
      "type": "enumeration",
      "enum": [
        "norte",
        "nordeste",
        "sul",
        "sudeste",
        "centro-oeste",
        "exterior"
      ],
      "required": true
    },
    "estado": {
      "type": "string",
      "required": true
    },
    "slug_estado": {
      "type": "string",
      "required": true
    },
    "descricao_geral": {
      "type": "richtext",
      "required": true
    },
    "imagem_capa": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "imagens": {
      "type": "media",
      "multiple": true,
      "required": false,
      "allowedTypes": ["images"]
    },
    "quando_ir": {
      "type": "richtext"
    },
    "o_que_fazer": {
      "type": "richtext"
    },
    "onde_ficar": {
      "type": "richtext"
    },
    "como_chegar": {
      "type": "richtext"
    },
    "aeroporto": {
      "type": "string"
    },
    "alta_temporada": {
      "type": "string"
    },
    "fuso_horario": {
      "type": "string"
    },
    "voltagem": {
      "type": "string"
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "codigo": {
      "type": "string"
    },
    "pais": {
      "type": "string"
    },
    "tipo": {
      "type": "enumeration",
      "enum": [
        "aeroporto",
        "rodoviaria",
        "porto",
        "cidade"
      ],
      "default": "cidade"
    },
    "atracoes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::atracao.atracao",
      "mappedBy": "destino"
    },
    "hoteis": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::hotel.hotel",
      "mappedBy": "destino"
    },
    "passagens_origem": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::passagem.passagem",
      "mappedBy": "origem"
    },
    "passagens_destino": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::passagem.passagem",
      "mappedBy": "destino_passagem"
    }
  }
}
